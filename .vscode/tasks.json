				"import json,urllib.request; base='http://127.0.0.1:8000';\nwith urllib.request.urlopen(base+'/health') as r: print('health', r.status, r.read().decode());\nwith urllib.request.urlopen(base+'/chapter?translation=kjv&bookId=romans&chapter=8') as r: data=json.loads(r.read().decode()); print('chapter_first_verse', data['verses'][0]['bookId'], f\"{data['verses'][0]['chapter']}:{data['verses'][0]['verse']}\");\npayload={'translation':'kjv','bookId':'romans','chapter':8,'verse':1,'style':'simple'};\nreq=urllib.request.Request(base+'/commentary/ensure', data=json.dumps(payload).encode('utf-8'), headers={'Content-Type':'application/json'}, method='POST');\nwith urllib.request.urlopen(req) as r: out=json.loads(r.read().decode()); print('commentary_stored', out.get('stored'));"
