# Copy this file to `server/app/.env` and fill in values.
# IMPORTANT: Do not commit real secrets.

# Required for the API (Postgres connection)
# If you're using the provided docker-compose Postgres (port 5433 on host):
# DATABASE_URL=postgresql+psycopg://bible:bible@localhost:5433/bible

# If you're using local Postgres (typical port 5432):
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/bible

# Optional: enable AI commentary generation via OpenAI-compatible Chat Completions
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=YOUR_KEY_HERE
# LLM_MODEL=gpt-4o-mini
# COMMENTARY_PROMPT_STYLE=simple

# Optional: sermon transcription speed/quality tuning
# tiny = fastest, base = balanced, small = better accuracy but slower
SERMON_TRANSCRIPTION_ENABLED=false
SERMON_WHISPER_MODEL=base
SERMON_WHISPER_DEVICE=cpu
SERMON_WHISPER_COMPUTE_TYPE=int8
